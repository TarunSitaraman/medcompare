# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini API - for prescription OCR
# Free: 1,500 requests/day, no credit card needed
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Vercel KV (Redis cache) - add from Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (email for price alerts) - free: 100 emails/day
RESEND_API_KEY=re_...

# Affiliate IDs (apply at each pharmacy)
AFFILIATE_1MG_ID=
AFFILIATE_PHARMEASY_ID=
AFFILIATE_NETMEDS_ID=
AFFILIATE_APOLLO_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
